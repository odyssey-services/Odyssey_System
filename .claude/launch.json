{
  "version": "0.0.1",
  "configurations": [
    {
      "name": "Dev Server (dev.mjs)",
      "runtimeExecutable": "node",
      "runtimeArgs": ["dev.mjs"],
      "port": 3000
    },
    {
      "name": "Build (esbuild)",
      "runtimeExecutable": "node",
      "runtimeArgs": ["build.mjs"],
      "port": null
    },
    {
      "name": "Static File Server (Python)",
      "runtimeExecutable": "python",
      "runtimeArgs": ["-m", "http.server", "3000", "--bind", "127.0.0.1"],
      "port": 3000
    },
    {
      "name": "Static File Server (npx http-server)",
      "runtimeExecutable": "npx",
      "runtimeArgs": ["http-server", "-p", "3000", "-a", "127.0.0.1"],
      "port": 3000
    }
  ]
}
